{
    "permissions": {
        "allow": [
            "Bash"
        ]
    },
    "hooks": {
        "Notification": [
            {
                "hooks": [{
                    "type": "command",
                    "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/slack_notify.ps1 notification"
                }]
            }
        ],
        "Stop": [
            {
                "hooks": [{
                    "type": "command",
                    "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/slack_notify.ps1 stop"
                }]
            }
        ]
    }
}
